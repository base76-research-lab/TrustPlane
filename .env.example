# CognOS Enterprise — Environment Variables
# Copy to .env and fill in your values

# Gateway
COGNOS_GATEWAY_API_KEY=test-key
COGNOS_DEFAULT_TENANT=demo
COGNOS_USE_POSTGRES=true

# LLM Provider (ollama | openai | anthropic | groq | cerebras)
COGNOS_PROVIDER=ollama
COGNOS_MODEL=llama3.2:1b

# Provider API keys (fill in as needed)
OLLAMA_HOST=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Database
DATABASE_URL=postgresql://cognos:cognos@localhost:5432/cognos
REDIS_URL=redis://localhost:6379/0

# Trust policy
COGNOS_TARGET_RISK=0.5

# OSS integrations
# cognos-proof-engine is bundled as gateway/
# cognos-session-memory: set API endpoint if running separately
COGNOS_SESSION_MEMORY_URL=
# token-compressor: set API endpoint if running separately
COGNOS_TOKEN_COMPRESSOR_URL=

# SaaS
STRIPE_WEBHOOK_SECRET=
